def fibonacci(n):
    """Calcula la serie Fibonacci hasta n términos"""
    if n <= 0:
        return []
    elif n == 1:
        return [0]
    elif n == 2:
        return [0, 1]
    
    serie = [0, 1]
    for i in range(2, n):
        serie.append(serie[i-1] + serie[i-2])
    return serie

# Ejemplo: Mostrar los primeros 10 números de Fibonacci
if __name__ == "__main__":
    num_terminos = 10
    resultado = fibonacci(num_terminos)
    print(f"Serie Fibonacci ({num_terminos} términos):")
    print(resultado)